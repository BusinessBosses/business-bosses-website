{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/businesstools",
      "destination": "https://businessbosses.news",
      "statusCode": 308,
      "regex": "^(?!/_next)/businesstools(?:/)?$"
    },
    {
      "source": "/news",
      "destination": "https://businessbosses.news",
      "statusCode": 308,
      "regex": "^(?!/_next)/news(?:/)?$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/becomeapartner",
      "regex": "^/becomeapartner(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/becomeapartner(?:/)?$"
    },
    {
      "page": "/landingpage",
      "regex": "^/landingpage(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/landingpage(?:/)?$"
    },
    {
      "page": "/landingpageforpartners",
      "regex": "^/landingpageforpartners(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/landingpageforpartners(?:/)?$"
    },
    {
      "page": "/privacypolicy",
      "regex": "^/privacypolicy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacypolicy(?:/)?$"
    },
    {
      "page": "/proscreens/biz-center/views/ManageInventory/ManageInventory",
      "regex": "^/proscreens/biz\\-center/views/ManageInventory/ManageInventory(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/proscreens/biz\\-center/views/ManageInventory/ManageInventory(?:/)?$"
    },
    {
      "page": "/proscreens/biz-center/views/ManageService/MyService",
      "regex": "^/proscreens/biz\\-center/views/ManageService/MyService(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/proscreens/biz\\-center/views/ManageService/MyService(?:/)?$"
    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}